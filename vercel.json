{
  "installCommand": "npm ci --no-audit --no-fund",
  "buildCommand": "npm run build:vercel",
  "crons": [
    {
      "path": "/api/cron/notifications",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/backup",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/monitor",
      "schedule": "0 9 * * *"
    }
  ]
}
