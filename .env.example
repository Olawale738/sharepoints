DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
AUTH_SECRET="replace-with-a-strong-random-secret"

AUTH_URL="http://localhost:3000"
SEED_ADMIN_EMAIL="president@letw.org"
SEED_ADMIN_PASSWORD="replace-with-a-private-admin-password"

RESEND_API_KEY=""
EMAIL_FROM="LETW <no-reply@letw.org>"

# WhatsApp Cloud API broadcasts
# Create these in Meta Business / WhatsApp Cloud API and add the same values to Vercel.
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_GRAPH_VERSION="v20.0"
WHATSAPP_DEFAULT_COUNTRY_CODE="234"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="replace-with-a-private-webhook-token"
WHATSAPP_APP_SECRET=""
# Optional approved template for first-time / organization-initiated broadcasts.
# The default supported template shape expects two body variables: {{1}} title and {{2}} message.
WHATSAPP_TEMPLATE_NAME=""
WHATSAPP_TEMPLATE_LANGUAGE="en"
WHATSAPP_TEMPLATE_HAS_BODY_PARAMS="true"

AWS_REGION="auto"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_S3_ENDPOINT=""
AWS_S3_PUBLIC_BASE_URL=""
AWS_S3_FORCE_PATH_STYLE="true"
MAX_UPLOAD_BYTES="52428800"
PUBLIC_SITE_FEED_TOKEN="change-this-token-before-connecting-letw-org"
RECYCLE_RETENTION_DAYS="30"

# Managed WebSocket realtime
ABLY_API_KEY=""

# OnlyOffice Document Server
ONLYOFFICE_DOCUMENT_SERVER_URL=""
ONLYOFFICE_JWT_SECRET=""

# Meeting transcription
OPENAI_API_KEY=""
OPENAI_TRANSCRIPTION_MODEL="gpt-4o-mini-transcribe"
OPENAI_TRANSLATION_MODEL="gpt-5-mini"

# Vercel Cron authentication
CRON_SECRET=""

# Jitsi video meetings
# Use meet.jit.si for testing, or your own Jitsi/Jibri or JaaS domain for production recording.
NEXT_PUBLIC_JITSI_DOMAIN="meet.jit.si"
# For JaaS, set this to your JaaS application id so rooms become {APP_ID}/{ROOM_NAME}.
NEXT_PUBLIC_JITSI_APP_ID=""

# Optional Apple / Google Wallet membership card issuing
APPLE_WALLET_PASS_TYPE_ID=""
APPLE_WALLET_TEAM_ID=""
APPLE_WALLET_CERTIFICATE_BASE64=""
APPLE_WALLET_CERTIFICATE_PASSWORD=""
GOOGLE_WALLET_ISSUER_ID=""
GOOGLE_WALLET_SERVICE_ACCOUNT_JSON_BASE64=""
