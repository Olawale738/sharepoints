generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  ADMIN     @map("admin")
  LEADER    @map("leader")
  MODERATOR @map("moderator")
  USER      @map("user")
  EDITOR    @map("editor")
  VIEWER    @map("viewer")
}

enum IntegrationType {
  WEBHOOK @map("webhook")
}

enum TaskStatus {
  TODO        @map("todo")
  IN_PROGRESS @map("in_progress")
  BLOCKED     @map("blocked")
  DONE        @map("done")
}

enum OrgChatAudience {
  ALL
  ADMIN
  LEADER
  MODERATOR
  USER
}

enum MeetingResponseStatus {
  YES
  MAYBE
  NO
}

enum MeetingType {
  AUDIO
  VIDEO
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum DepartmentKind {
  DEPARTMENT
  MINISTRY_UNIT
  CATEGORY
}

enum SecurityEventType {
  LOGIN_SUCCESS
  LOGIN_FAILED
  PASSWORD_RESET
  SESSION_REVOKED
  FORCE_PASSWORD_RESET
  USER_SUSPENDED
  USER_RESTORED
  ACCESS_REVOKED
  USER_DELETED
}

model User {
  id                         String                     @id @default(cuid())
  name                       String?
  email                      String?                    @unique
  emailVerified              DateTime?
  image                      String?
  passwordHash               String?
  departmentId               String?
  category                   String?
  forcePasswordReset         Boolean                    @default(false)
  singleActiveSession        Boolean                    @default(false)
  sessionVersion             Int                        @default(0)
  suspendedAt                DateTime?
  accessRevokedAt            DateTime?
  deletedAt                  DateTime?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  accounts                   Account[]
  sessions                   Session[]
  authenticators             Authenticator[]
  department                 Department?                @relation("DepartmentMembers", fields: [departmentId], references: [id], onDelete: SetNull)
  departmentsCreated         Department[]               @relation("DepartmentsCreated")
  passwordResetTokens        PasswordResetToken[]
  approvalRequests           ApprovalRequest[]          @relation("ApprovalRequester")
  approvalReviews            ApprovalRequest[]          @relation("ApprovalReviewer")
  companyInvitationsSent     CompanyEmailInvitation[]   @relation("CompanyInvitationsSent")
  companyInvitationsAccepted CompanyEmailInvitation[]   @relation("CompanyInvitationsAccepted")
  createdWorkspaces          Workspace[]                @relation("WorkspaceCreator")
  workspaceMemberships       WorkspaceMember[]
  uploadedFiles              File[]                     @relation("UploadedFiles")
  createdFolders             Folder[]                   @relation("CreatedFolders")
  createdChannels            ChatChannel[]              @relation("CreatedChannels")
  chatMessages               ChatMessage[]              @relation("AuthoredMessages")
  createdOrgChatRooms        OrgChatRoom[]              @relation("CreatedOrgChatRooms")
  orgChatMessages            OrgChatMessage[]           @relation("AuthoredOrgChatMessages")
  createdDirectConversations DirectConversation[]       @relation("CreatedDirectConversations")
  directConversationsAsA     DirectConversation[]       @relation("DirectParticipantA")
  directConversationsAsB     DirectConversation[]       @relation("DirectParticipantB")
  directMessages             DirectMessage[]            @relation("AuthoredDirectMessages")
  createdIntegrations        Integration[]              @relation("CreatedIntegrations")
  authoredAnnouncements      WorkspaceAnnouncement[]    @relation("AuthoredAnnouncements")
  assignedTasks              WorkspaceTask[]            @relation("AssignedTasks")
  taskAssignments            WorkspaceTaskAssignee[]
  taskComments               WorkspaceTaskComment[]
  createdTasks               WorkspaceTask[]            @relation("CreatedTasks")
  createdMeetings            WorkspaceMeeting[]         @relation("CreatedMeetings")
  meetingResponses           WorkspaceMeetingResponse[]
  createdShareLinks          FileShareLink[]            @relation("CreatedShareLinks")
  securityEvents             SecurityEvent[]
  activityLogs               ActivityLog[]

  @@index([departmentId])
  @@index([category])
  @@index([forcePasswordReset])
  @@index([singleActiveSession])
  @@index([sessionVersion])
  @@index([suspendedAt])
  @@index([accessRevokedAt])
  @@index([deletedAt])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Department {
  id              String                      @id @default(cuid())
  name            String
  kind            DepartmentKind              @default(DEPARTMENT)
  description     String?
  createdById     String?
  createdBy       User?                       @relation("DepartmentsCreated", fields: [createdById], references: [id], onDelete: SetNull)
  members         User[]                      @relation("DepartmentMembers")
  workspaceAccess WorkspaceDepartmentAccess[]
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  @@unique([name, kind])
  @@index([kind])
  @@index([createdById])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, expiresAt])
  @@index([userId, createdAt])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model CompanyEmailInvitation {
  id           String    @id @default(cuid())
  email        String    @unique
  invitedById  String?
  acceptedById String?
  acceptedAt   DateTime?
  revokedAt    DateTime?
  invitedBy    User?     @relation("CompanyInvitationsSent", fields: [invitedById], references: [id], onDelete: SetNull)
  acceptedBy   User?     @relation("CompanyInvitationsAccepted", fields: [acceptedById], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email, revokedAt])
  @@index([invitedById, createdAt])
  @@index([acceptedById, acceptedAt])
}

model Workspace {
  id                  String                      @id @default(cuid())
  name                String
  slug                String                      @unique
  description         String?
  joinCode            String                      @unique @default(cuid())
  createdById         String
  createdBy           User                        @relation("WorkspaceCreator", fields: [createdById], references: [id], onDelete: Restrict)
  members             WorkspaceMember[]
  rolePermissions     WorkspaceRolePermission[]
  departmentAccesses  WorkspaceDepartmentAccess[]
  announcements       WorkspaceAnnouncement[]
  tasks               WorkspaceTask[]
  meetings            WorkspaceMeeting[]
  folders             Folder[]
  files               File[]
  chatChannels        ChatChannel[]
  directConversations DirectConversation[]
  integrations        Integration[]
  activityLogs        ActivityLog[]
  approvalRequests    ApprovalRequest[]
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  @@index([createdById])
}

model WorkspaceDepartmentAccess {
  id                 String     @id @default(cuid())
  workspaceId        String
  departmentId       String
  canAccessWorkspace Boolean    @default(true)
  canAccessChat      Boolean    @default(true)
  workspace          Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  department         Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@unique([workspaceId, departmentId])
  @@index([departmentId])
}

model WorkspaceMeeting {
  id                 String                     @id @default(cuid())
  workspaceId        String
  createdById        String
  title              String
  description        String?
  agenda             String?
  notes              String?
  actionItems        String?
  recordingUrl       String?
  autoRecord         Boolean                    @default(false)
  recordingMode      String                     @default("file")
  recordingStatus    String?
  recordingError     String?
  recordingStartedAt DateTime?
  meetingType        MeetingType                @default(VIDEO)
  startsAt           DateTime
  endsAt             DateTime
  roomName           String                     @unique
  passcode           String
  cancelledAt        DateTime?
  approvalStatus     ApprovalStatus             @default(APPROVED)
  approvedById       String?
  approvedAt         DateTime?
  rejectedReason     String?
  workspace          Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy          User                       @relation("CreatedMeetings", fields: [createdById], references: [id], onDelete: Restrict)
  responses          WorkspaceMeetingResponse[]
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@index([workspaceId, startsAt])
  @@index([workspaceId, meetingType, startsAt])
  @@index([workspaceId, approvalStatus])
  @@index([createdById, startsAt])
  @@index([cancelledAt])
}

model WorkspaceMeetingResponse {
  id        String                @id @default(cuid())
  meetingId String
  userId    String
  status    MeetingResponseStatus
  meeting   WorkspaceMeeting      @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@unique([meetingId, userId])
  @@index([meetingId, status])
  @@index([userId, updatedAt])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole @default(USER)
  joinedAt    DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId, role])
}

model WorkspaceRolePermission {
  id                     String        @id @default(cuid())
  workspaceId            String
  role                   WorkspaceRole
  canUploadFiles         Boolean       @default(false)
  canDeleteFiles         Boolean       @default(false)
  canCreateFolders       Boolean       @default(false)
  canCreateChannels      Boolean       @default(false)
  canSendMessages        Boolean       @default(true)
  canManageMembers       Boolean       @default(false)
  canManageIntegrations  Boolean       @default(false)
  canViewActivity        Boolean       @default(false)
  canCreateAnnouncements Boolean       @default(false)
  canManageTasks         Boolean       @default(false)
  canScheduleMeetings    Boolean       @default(false)
  canCreateShareLinks    Boolean       @default(false)
  workspace              Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@unique([workspaceId, role])
  @@index([workspaceId])
}

model WorkspaceAnnouncement {
  id             String         @id @default(cuid())
  workspaceId    String
  authorId       String
  title          String
  body           String         @db.Text
  pinned         Boolean        @default(false)
  approvalStatus ApprovalStatus @default(APPROVED)
  approvedById   String?
  approvedAt     DateTime?
  rejectedReason String?
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author         User           @relation("AuthoredAnnouncements", fields: [authorId], references: [id], onDelete: Restrict)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([workspaceId, pinned, createdAt])
  @@index([workspaceId, approvalStatus])
  @@index([authorId, createdAt])
}

model WorkspaceTask {
  id             String                  @id @default(cuid())
  workspaceId    String
  title          String
  description    String?
  status         TaskStatus              @default(TODO)
  priority       TaskPriority            @default(NORMAL)
  dueDate        DateTime?
  reminderAt     DateTime?
  assignedToId   String?
  createdById    String
  approvalStatus ApprovalStatus          @default(APPROVED)
  approvedById   String?
  approvedAt     DateTime?
  rejectedReason String?
  workspace      Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedTo     User?                   @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignees      WorkspaceTaskAssignee[]
  comments       WorkspaceTaskComment[]
  createdBy      User                    @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([workspaceId, status, dueDate])
  @@index([workspaceId, approvalStatus])
  @@index([workspaceId, priority])
  @@index([reminderAt])
  @@index([assignedToId, status])
  @@index([createdById, createdAt])
}

model WorkspaceTaskAssignee {
  id        String        @id @default(cuid())
  taskId    String
  userId    String
  task      WorkspaceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([taskId, userId])
  @@index([userId])
}

model WorkspaceTaskComment {
  id        String        @id @default(cuid())
  taskId    String
  authorId  String
  body      String        @db.Text
  task      WorkspaceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@index([taskId, createdAt])
  @@index([authorId, createdAt])
}

model Folder {
  id          String    @id @default(cuid())
  workspaceId String
  parentId    String?
  name        String
  createdById String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent      Folder?   @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    Folder[]  @relation("FolderTree")
  createdBy   User      @relation("CreatedFolders", fields: [createdById], references: [id], onDelete: Restrict)
  files       File[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId, parentId])
}

model File {
  id             String          @id @default(cuid())
  workspaceId    String
  folderId       String?
  uploadedById   String
  fileUrl        String
  storageKey     String          @unique
  fileName       String
  fileType       String
  size           Int
  approvalStatus ApprovalStatus  @default(APPROVED)
  approvedById   String?
  approvedAt     DateTime?
  rejectedReason String?
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folder         Folder?         @relation(fields: [folderId], references: [id], onDelete: SetNull)
  uploadedBy     User            @relation("UploadedFiles", fields: [uploadedById], references: [id], onDelete: Restrict)
  chatMessages   ChatMessage[]   @relation("MessageAttachment")
  shareLinks     FileShareLink[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([workspaceId, folderId])
  @@index([workspaceId, approvalStatus])
  @@index([uploadedById])
}

model FileShareLink {
  id          String    @id @default(cuid())
  fileId      String
  createdById String
  token       String    @unique
  expiresAt   DateTime?
  file        File      @relation(fields: [fileId], references: [id], onDelete: Cascade)
  createdBy   User      @relation("CreatedShareLinks", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())

  @@index([fileId, createdAt])
  @@index([expiresAt])
}

model ChatChannel {
  id           String        @id @default(cuid())
  workspaceId  String
  name         String
  description  String?
  createdById  String
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy    User          @relation("CreatedChannels", fields: [createdById], references: [id], onDelete: Restrict)
  messages     ChatMessage[]
  integrations Integration[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([workspaceId, name])
  @@index([workspaceId, createdAt])
}

model ChatMessage {
  id               String      @id @default(cuid())
  channelId        String
  authorId         String?
  externalAuthor   String?
  body             String      @db.Text
  attachmentFileId String?
  voiceStorageKey  String?     @unique
  voiceMimeType    String?
  voiceSize        Int?
  voiceDurationMs  Int?
  editedAt         DateTime?
  deletedAt        DateTime?
  channel          ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author           User?       @relation("AuthoredMessages", fields: [authorId], references: [id], onDelete: SetNull)
  attachmentFile   File?       @relation("MessageAttachment", fields: [attachmentFileId], references: [id], onDelete: SetNull)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([channelId, createdAt])
  @@index([authorId, createdAt])
  @@index([deletedAt])
}

model DirectConversation {
  id             String          @id @default(cuid())
  workspaceId    String
  createdById    String?
  participantAId String
  participantBId String
  lastMessageAt  DateTime?
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy      User?           @relation("CreatedDirectConversations", fields: [createdById], references: [id], onDelete: SetNull)
  participantA   User            @relation("DirectParticipantA", fields: [participantAId], references: [id], onDelete: Cascade)
  participantB   User            @relation("DirectParticipantB", fields: [participantBId], references: [id], onDelete: Cascade)
  messages       DirectMessage[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([workspaceId, participantAId, participantBId])
  @@index([workspaceId, updatedAt])
  @@index([participantAId, updatedAt])
  @@index([participantBId, updatedAt])
}

model DirectMessage {
  id              String             @id @default(cuid())
  conversationId  String
  authorId        String
  body            String             @db.Text
  voiceStorageKey String?            @unique
  voiceMimeType   String?
  voiceSize       Int?
  voiceDurationMs Int?
  editedAt        DateTime?
  deletedAt       DateTime?
  conversation    DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author          User               @relation("AuthoredDirectMessages", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt       DateTime           @default(now())

  @@index([conversationId, createdAt])
  @@index([authorId, createdAt])
  @@index([deletedAt])
}

model OrgChatRoom {
  id          String           @id @default(cuid())
  audience    OrgChatAudience  @unique
  name        String
  description String?
  createdById String?
  createdBy   User?            @relation("CreatedOrgChatRooms", fields: [createdById], references: [id], onDelete: SetNull)
  messages    OrgChatMessage[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([audience])
  @@index([createdAt])
}

model OrgChatMessage {
  id              String      @id @default(cuid())
  roomId          String
  authorId        String
  body            String      @db.Text
  voiceStorageKey String?     @unique
  voiceMimeType   String?
  voiceSize       Int?
  voiceDurationMs Int?
  editedAt        DateTime?
  deletedAt       DateTime?
  room            OrgChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author          User        @relation("AuthoredOrgChatMessages", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([roomId, createdAt])
  @@index([authorId, createdAt])
  @@index([deletedAt])
}

model Integration {
  id            String          @id @default(cuid())
  workspaceId   String
  channelId     String?
  createdById   String
  name          String
  type          IntegrationType @default(WEBHOOK)
  webhookSecret String          @unique @default(cuid())
  targetUrl     String?
  enabled       Boolean         @default(true)
  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel       ChatChannel?    @relation(fields: [channelId], references: [id], onDelete: SetNull)
  createdBy     User            @relation("CreatedIntegrations", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([workspaceId, enabled])
  @@index([channelId])
}

model ActivityLog {
  id          String     @id @default(cuid())
  userId      String?
  workspaceId String?
  action      String
  targetId    String?
  metadata    Json?
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
}

model ApprovalRequest {
  id          String         @id @default(cuid())
  workspaceId String
  requesterId String
  reviewerId  String?
  targetType  String
  targetId    String
  title       String
  status      ApprovalStatus @default(PENDING)
  reason      String?
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requester   User           @relation("ApprovalRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  reviewer    User?          @relation("ApprovalReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())
  reviewedAt  DateTime?
  updatedAt   DateTime       @updatedAt

  @@unique([targetType, targetId])
  @@index([workspaceId, status, createdAt])
  @@index([requesterId, createdAt])
  @@index([reviewerId, reviewedAt])
}

model SecurityEvent {
  id        String            @id @default(cuid())
  userId    String?
  type      SecurityEventType
  email     String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  user      User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime          @default(now())

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([type, createdAt])
}
