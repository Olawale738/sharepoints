generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  ADMIN     @map("admin")
  LEADER    @map("leader")
  MODERATOR @map("moderator")
  USER      @map("user")
  EDITOR    @map("editor")
  VIEWER    @map("viewer")
}

enum IntegrationType {
  WEBHOOK @map("webhook")
}

enum TaskStatus {
  TODO        @map("todo")
  IN_PROGRESS @map("in_progress")
  BLOCKED     @map("blocked")
  DONE        @map("done")
}

enum OrgChatAudience {
  ALL
  ADMIN
  LEADER
  MODERATOR
  USER
}

model User {
  id                         String                   @id @default(cuid())
  name                       String?
  email                      String?                  @unique
  emailVerified              DateTime?
  image                      String?
  passwordHash               String?
  suspendedAt                DateTime?
  accessRevokedAt            DateTime?
  deletedAt                  DateTime?
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  accounts                   Account[]
  sessions                   Session[]
  authenticators             Authenticator[]
  passwordResetTokens        PasswordResetToken[]
  companyInvitationsSent     CompanyEmailInvitation[] @relation("CompanyInvitationsSent")
  companyInvitationsAccepted CompanyEmailInvitation[] @relation("CompanyInvitationsAccepted")
  createdWorkspaces          Workspace[]              @relation("WorkspaceCreator")
  workspaceMemberships       WorkspaceMember[]
  uploadedFiles              File[]                   @relation("UploadedFiles")
  createdFolders             Folder[]                 @relation("CreatedFolders")
  createdChannels            ChatChannel[]            @relation("CreatedChannels")
  chatMessages               ChatMessage[]            @relation("AuthoredMessages")
  createdOrgChatRooms        OrgChatRoom[]            @relation("CreatedOrgChatRooms")
  orgChatMessages            OrgChatMessage[]         @relation("AuthoredOrgChatMessages")
  createdDirectConversations DirectConversation[]     @relation("CreatedDirectConversations")
  directConversationsAsA     DirectConversation[]     @relation("DirectParticipantA")
  directConversationsAsB     DirectConversation[]     @relation("DirectParticipantB")
  directMessages             DirectMessage[]          @relation("AuthoredDirectMessages")
  createdIntegrations        Integration[]            @relation("CreatedIntegrations")
  authoredAnnouncements      WorkspaceAnnouncement[]  @relation("AuthoredAnnouncements")
  assignedTasks              WorkspaceTask[]          @relation("AssignedTasks")
  createdTasks               WorkspaceTask[]          @relation("CreatedTasks")
  createdShareLinks          FileShareLink[]          @relation("CreatedShareLinks")
  activityLogs               ActivityLog[]

  @@index([suspendedAt])
  @@index([accessRevokedAt])
  @@index([deletedAt])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, expiresAt])
  @@index([userId, createdAt])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model CompanyEmailInvitation {
  id           String    @id @default(cuid())
  email        String    @unique
  invitedById  String?
  acceptedById String?
  acceptedAt   DateTime?
  revokedAt    DateTime?
  invitedBy    User?     @relation("CompanyInvitationsSent", fields: [invitedById], references: [id], onDelete: SetNull)
  acceptedBy   User?     @relation("CompanyInvitationsAccepted", fields: [acceptedById], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email, revokedAt])
  @@index([invitedById, createdAt])
  @@index([acceptedById, acceptedAt])
}

model Workspace {
  id                  String                    @id @default(cuid())
  name                String
  slug                String                    @unique
  description         String?
  joinCode            String                    @unique @default(cuid())
  createdById         String
  createdBy           User                      @relation("WorkspaceCreator", fields: [createdById], references: [id], onDelete: Restrict)
  members             WorkspaceMember[]
  rolePermissions     WorkspaceRolePermission[]
  announcements       WorkspaceAnnouncement[]
  tasks               WorkspaceTask[]
  folders             Folder[]
  files               File[]
  chatChannels        ChatChannel[]
  directConversations DirectConversation[]
  integrations        Integration[]
  activityLogs        ActivityLog[]
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@index([createdById])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole @default(USER)
  joinedAt    DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId, role])
}

model WorkspaceRolePermission {
  id                     String        @id @default(cuid())
  workspaceId            String
  role                   WorkspaceRole
  canUploadFiles         Boolean       @default(false)
  canDeleteFiles         Boolean       @default(false)
  canCreateFolders       Boolean       @default(false)
  canCreateChannels      Boolean       @default(false)
  canSendMessages        Boolean       @default(true)
  canManageMembers       Boolean       @default(false)
  canManageIntegrations  Boolean       @default(false)
  canViewActivity        Boolean       @default(false)
  canCreateAnnouncements Boolean       @default(false)
  canManageTasks         Boolean       @default(false)
  canCreateShareLinks    Boolean       @default(false)
  workspace              Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@unique([workspaceId, role])
  @@index([workspaceId])
}

model WorkspaceAnnouncement {
  id          String    @id @default(cuid())
  workspaceId String
  authorId    String
  title       String
  body        String    @db.Text
  pinned      Boolean   @default(false)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author      User      @relation("AuthoredAnnouncements", fields: [authorId], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId, pinned, createdAt])
  @@index([authorId, createdAt])
}

model WorkspaceTask {
  id           String     @id @default(cuid())
  workspaceId  String
  title        String
  description  String?
  status       TaskStatus @default(TODO)
  dueDate      DateTime?
  assignedToId String?
  createdById  String
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedTo   User?      @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy    User       @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([workspaceId, status, dueDate])
  @@index([assignedToId, status])
  @@index([createdById, createdAt])
}

model Folder {
  id          String    @id @default(cuid())
  workspaceId String
  parentId    String?
  name        String
  createdById String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent      Folder?   @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    Folder[]  @relation("FolderTree")
  createdBy   User      @relation("CreatedFolders", fields: [createdById], references: [id], onDelete: Restrict)
  files       File[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId, parentId])
}

model File {
  id           String          @id @default(cuid())
  workspaceId  String
  folderId     String?
  uploadedById String
  fileUrl      String
  storageKey   String          @unique
  fileName     String
  fileType     String
  size         Int
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folder       Folder?         @relation(fields: [folderId], references: [id], onDelete: SetNull)
  uploadedBy   User            @relation("UploadedFiles", fields: [uploadedById], references: [id], onDelete: Restrict)
  chatMessages ChatMessage[]   @relation("MessageAttachment")
  shareLinks   FileShareLink[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([workspaceId, folderId])
  @@index([uploadedById])
}

model FileShareLink {
  id          String    @id @default(cuid())
  fileId      String
  createdById String
  token       String    @unique
  expiresAt   DateTime?
  file        File      @relation(fields: [fileId], references: [id], onDelete: Cascade)
  createdBy   User      @relation("CreatedShareLinks", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())

  @@index([fileId, createdAt])
  @@index([expiresAt])
}

model ChatChannel {
  id           String        @id @default(cuid())
  workspaceId  String
  name         String
  description  String?
  createdById  String
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy    User          @relation("CreatedChannels", fields: [createdById], references: [id], onDelete: Restrict)
  messages     ChatMessage[]
  integrations Integration[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([workspaceId, name])
  @@index([workspaceId, createdAt])
}

model ChatMessage {
  id               String      @id @default(cuid())
  channelId        String
  authorId         String?
  externalAuthor   String?
  body             String      @db.Text
  attachmentFileId String?
  editedAt         DateTime?
  deletedAt        DateTime?
  channel          ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author           User?       @relation("AuthoredMessages", fields: [authorId], references: [id], onDelete: SetNull)
  attachmentFile   File?       @relation("MessageAttachment", fields: [attachmentFileId], references: [id], onDelete: SetNull)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([channelId, createdAt])
  @@index([authorId, createdAt])
  @@index([deletedAt])
}

model DirectConversation {
  id             String          @id @default(cuid())
  workspaceId    String
  createdById    String?
  participantAId String
  participantBId String
  lastMessageAt  DateTime?
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy      User?           @relation("CreatedDirectConversations", fields: [createdById], references: [id], onDelete: SetNull)
  participantA   User            @relation("DirectParticipantA", fields: [participantAId], references: [id], onDelete: Cascade)
  participantB   User            @relation("DirectParticipantB", fields: [participantBId], references: [id], onDelete: Cascade)
  messages       DirectMessage[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([workspaceId, participantAId, participantBId])
  @@index([workspaceId, updatedAt])
  @@index([participantAId, updatedAt])
  @@index([participantBId, updatedAt])
}

model DirectMessage {
  id             String             @id @default(cuid())
  conversationId String
  authorId       String
  body           String             @db.Text
  editedAt       DateTime?
  deletedAt      DateTime?
  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author         User               @relation("AuthoredDirectMessages", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())

  @@index([conversationId, createdAt])
  @@index([authorId, createdAt])
  @@index([deletedAt])
}

model OrgChatRoom {
  id          String           @id @default(cuid())
  audience    OrgChatAudience  @unique
  name        String
  description String?
  createdById String?
  createdBy   User?            @relation("CreatedOrgChatRooms", fields: [createdById], references: [id], onDelete: SetNull)
  messages    OrgChatMessage[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([audience])
  @@index([createdAt])
}

model OrgChatMessage {
  id        String      @id @default(cuid())
  roomId    String
  authorId  String
  body      String      @db.Text
  editedAt  DateTime?
  deletedAt DateTime?
  room      OrgChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author    User        @relation("AuthoredOrgChatMessages", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([roomId, createdAt])
  @@index([authorId, createdAt])
  @@index([deletedAt])
}

model Integration {
  id            String          @id @default(cuid())
  workspaceId   String
  channelId     String?
  createdById   String
  name          String
  type          IntegrationType @default(WEBHOOK)
  webhookSecret String          @unique @default(cuid())
  targetUrl     String?
  enabled       Boolean         @default(true)
  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel       ChatChannel?    @relation(fields: [channelId], references: [id], onDelete: SetNull)
  createdBy     User            @relation("CreatedIntegrations", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([workspaceId, enabled])
  @@index([channelId])
}

model ActivityLog {
  id          String     @id @default(cuid())
  userId      String?
  workspaceId String?
  action      String
  targetId    String?
  metadata    Json?
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
}
