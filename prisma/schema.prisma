model User {
  id                         String                       @id @default(cuid())
  name                       String?
  email                      String?                      @unique
  emailVerified              DateTime?
  image                      String?
  passwordHash               String?
  departmentId               String?
  category                   String?
  forcePasswordReset         Boolean                      @default(false)
  singleActiveSession        Boolean                      @default(false)
  sessionVersion             Int                          @default(0)
  twoFactorSecret            String?
  twoFactorEnabled           Boolean                      @default(false)
  suspendedAt                DateTime?
  accessRevokedAt            DateTime?
  deletedAt                  DateTime?
  locale                     String                       @default("en")
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt
  accounts                   Account[]
  sessions                   Session[]
  authenticators             Authenticator[]
  department                 Department?                  @relation("DepartmentMembers", fields: [departmentId], references: [id], onDelete: SetNull)
  departmentsCreated         Department[]                 @relation("DepartmentsCreated")
  passwordResetTokens        PasswordResetToken[]
  approvalRequests           ApprovalRequest[]            @relation("ApprovalRequester")
  approvalReviews            ApprovalRequest[]            @relation("ApprovalReviewer")
  companyInvitationsSent     CompanyEmailInvitation[]     @relation("CompanyInvitationsSent")
  companyInvitationsAccepted CompanyEmailInvitation[]     @relation("CompanyInvitationsAccepted")
  createdWorkspaces          Workspace[]                  @relation("WorkspaceCreator")
  workspaceMemberships       WorkspaceMember[]
  uploadedFiles              File[]                       @relation("UploadedFiles")
  createdFolders             Folder[]                     @relation("CreatedFolders")
  createdChannels            ChatChannel[]                @relation("CreatedChannels")
  chatMessages               ChatMessage[]                @relation("AuthoredMessages")
  createdOrgChatRooms        OrgChatRoom[]                @relation("CreatedOrgChatRooms")
  orgChatMessages            OrgChatMessage[]             @relation("AuthoredOrgChatMessages")
  createdDirectConversations DirectConversation[]         @relation("CreatedDirectConversations")
  directConversationsAsA     DirectConversation[]         @relation("DirectParticipantA")
  directConversationsAsB     DirectConversation[]         @relation("DirectParticipantB")
  directMessages             DirectMessage[]              @relation("AuthoredDirectMessages")
  createdIntegrations        Integration[]                @relation("CreatedIntegrations")
  authoredAnnouncements      WorkspaceAnnouncement[]      @relation("AuthoredAnnouncements")
  assignedTasks              WorkspaceTask[]              @relation("AssignedTasks")
  taskAssignments            WorkspaceTaskAssignee[]
  taskComments               WorkspaceTaskComment[]
  createdTasks               WorkspaceTask[]              @relation("CreatedTasks")
  createdMeetings            WorkspaceMeeting[]           @relation("CreatedMeetings")
  meetingResponses           WorkspaceMeetingResponse[]
  createdShareLinks          FileShareLink[]              @relation("CreatedShareLinks")
  securityEvents             SecurityEvent[]
  notifications              Notification[]
  notificationDeliveryEvents NotificationDeliveryEvent[]
  notificationPreference     NotificationPreference?
  presence                   UserPresence?
  typingStates               ChatTypingState[]
  messageReactions           MessageReaction[]
  messageReceipts            MessageReadReceipt[]
  messageBookmarks           MessageBookmark[]
  messagePins                MessagePin[]                 @relation("MessagePinnedBy")
  devices                    UserDevice[]
  fileVersions               FileVersion[]                @relation("FileVersionUploader")
  fileComments               FileComment[]
  filesCheckedOut            File[]                       @relation("FileCheckedOutBy")
  filesClassified            File[]                       @relation("FileClassifiedBy")
  accessRequests             AccessRequest[]              @relation("AccessRequestRequester")
  accessRequestReviews       AccessRequest[]              @relation("AccessRequestReviewer")
  temporaryWorkspaceAccess   TemporaryWorkspaceAccess[]   @relation("TemporaryWorkspaceAccessUser")
  temporaryAccessIssued      TemporaryWorkspaceAccess[]   @relation("TemporaryWorkspaceAccessIssuer")
  fileAccessGrants           FileAccessGrant[]            @relation("FileAccessGrantUser")
  fileAccessGrantsIssued     FileAccessGrant[]            @relation("FileAccessGrantIssuer")
  leadershipDocuments        LeadershipDocument[]         @relation("LeadershipDocumentUploader")
  wikiPagesAuthored          WikiPage[]                   @relation("WikiPageAuthor")
  wikiPagesUpdated           WikiPage[]                   @relation("WikiPageUpdater")
  formsCreated               WorkspaceForm[]              @relation("FormCreator")
  formResponses              WorkspaceFormResponse[]
  activityLogs               ActivityLog[]
  memberProfile              MemberProfile?
  aiAssistantThreads         AiAssistantThread[]
  aiAssistantAudits          AiAssistantAudit[]
  complianceCampaignsCreated MemberComplianceCampaign[]   @relation("ComplianceCampaignCreator")
  complianceAssignments      MemberComplianceAssignment[] @relation("ComplianceAssignmentMember")
  complianceReviews          MemberComplianceAssignment[] @relation("ComplianceAssignmentReviewer")
  sanctionsReceived          MemberSanction[]             @relation("SanctionedMember")
  sanctionsIssued            MemberSanction[]             @relation("SanctionIssuer")
  sanctionsLifted            MemberSanction[]             @relation("SanctionLifter")
  officialIssuanceGrant      OfficialIssuanceGrant?       @relation("OfficialIssuanceGrantUser")
  officialIssuanceGrantsMade OfficialIssuanceGrant[]      @relation("OfficialIssuanceGrantIssuer")

  @@index([departmentId])
  @@index([category])
  @@index([forcePasswordReset])
  @@index([singleActiveSession])
  @@index([sessionVersion])
  @@index([twoFactorEnabled])
  @@index([suspendedAt])
  @@index([accessRevokedAt])
  @@index([deletedAt])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Department {
  id              String                      @id @default(cuid())
  name            String
  kind            DepartmentKind              @default(DEPARTMENT)
  description     String?
  createdById     String?
  createdBy       User?                       @relation("DepartmentsCreated", fields: [createdById], references: [id], onDelete: SetNull)
  members         User[]                      @relation("DepartmentMembers")
  workspaceAccess WorkspaceDepartmentAccess[]
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  @@unique([name, kind])
  @@index([kind])
  @@index([createdById])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, expiresAt])
  @@index([userId, createdAt])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model CompanyEmailInvitation {
  id           String    @id @default(cuid())
  email        String    @unique
  invitedById  String?
  acceptedById String?
  acceptedAt   DateTime?
  revokedAt    DateTime?
  invitedBy    User?     @relation("CompanyInvitationsSent", fields: [invitedById], references: [id], onDelete: SetNull)
  acceptedBy   User?     @relation("CompanyInvitationsAccepted", fields: [acceptedById], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email, revokedAt])
  @@index([invitedById, createdAt])
  @@index([acceptedById, acceptedAt])
}

model Workspace {
  id                  String                      @id @default(cuid())
  name                String
  slug                String                      @unique
  description         String?
  joinCode            String                      @unique @default(cuid())
  createdById         String
  createdBy           User                        @relation("WorkspaceCreator", fields: [createdById], references: [id], onDelete: Restrict)
  members             WorkspaceMember[]
  temporaryAccessGrants TemporaryWorkspaceAccess[]
  rolePermissions     WorkspaceRolePermission[]
  accessRequests      AccessRequest[]
  departmentAccesses  WorkspaceDepartmentAccess[]
  announcements       WorkspaceAnnouncement[]
  tasks               WorkspaceTask[]
  meetings            WorkspaceMeeting[]
  folders             Folder[]
  files               File[]
  chatChannels        ChatChannel[]
  directConversations DirectConversation[]
  integrations        Integration[]
  activityLogs        ActivityLog[]
  approvalRequests    ApprovalRequest[]
  wikiPages           WikiPage[]
  forms               WorkspaceForm[]
  notifications       Notification[]
  messagePins         MessagePin[]
  templateId          String?
  organizationUnitId  String?
  scopeType           OrganizationUnitType?
  audienceMode        WorkspaceAudienceMode       @default(WORKER_TEAM)
  memberDirectoryOpen Boolean                     @default(false)
  deletedAt           DateTime?
  deletedById         String?
  restoreUntil        DateTime?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  @@index([createdById])
  @@index([deletedAt, restoreUntil])
  @@index([templateId])
  @@index([organizationUnitId, scopeType])
  @@index([audienceMode])
}

model WorkspaceDepartmentAccess {
  id                 String     @id @default(cuid())
  workspaceId        String
  departmentId       String
  canAccessWorkspace Boolean    @default(true)
  canAccessChat      Boolean    @default(true)
  workspace          Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  department         Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@unique([workspaceId, departmentId])
  @@index([departmentId])
}

model WorkspaceMeeting {
  id                 String                     @id @default(cuid())
  workspaceId        String
  createdById        String
  title              String
  description        String?
  agenda             String?
  notes              String?
  actionItems        String?
  recordingUrl       String?
  autoRecord         Boolean                    @default(false)
  recordingMode      String                     @default("file")
  recordingStatus    String?
  recordingError     String?
  recordingStartedAt DateTime?
  meetingType        MeetingType                @default(VIDEO)
  startsAt           DateTime
  endsAt             DateTime
  roomName           String                     @unique
  passcode           String
  cancelledAt        DateTime?
  approvalStatus     ApprovalStatus             @default(APPROVED)
  approvedById       String?
  approvedAt         DateTime?
  rejectedReason     String?
  transcriptStatus   TranscriptStatus           @default(PENDING)
  transcript         String?                    @db.Text
  transcriptSummary  String?                    @db.Text
  transcriptLanguage String?
  workspace          Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy          User                       @relation("CreatedMeetings", fields: [createdById], references: [id], onDelete: Restrict)
  responses          WorkspaceMeetingResponse[]
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@index([workspaceId, startsAt])
